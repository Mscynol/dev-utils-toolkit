{
  "name": "@dev/utils-toolkit",
  "version": "1.0.0",
  "description": "实用的开发工具函数库，包含 JavaScript 和 Python 工具集",
  "main": "src/js/index.js",
  "module": "src/js/index.js",
  "types": "types/index.d.ts",
  "files": [
    "src/js/",
    "src/python/",
    "types/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/js/ tests/js/",
    "lint:fix": "eslint src/js/ tests/js/ --fix",
    "format": "prettier --write src/js/ tests/js/",
    "format:check": "prettier --check src/js/ tests/js/"
  },
  "keywords": [
    "utils",
    "toolkit",
    "utilities",
    "helpers",
    "date",
    "string",
    "array",
    "validation",
    "storage",
    "javascript",
    "typescript",
    "es6"
  ],
  "author": "Alexis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mscynol/dev-utils-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Mscynol/dev-utils-toolkit/issues"
  },
  "homepage": "https://github.com/Mscynol/dev-utils-toolkit#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/js/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
